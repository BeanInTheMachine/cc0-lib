# Required for submit endpoint
SUBMIT_SECRET=             # Shared secret for POST /api/submit authentication
GITHUB_TOKEN=              # GitHub PAT with repo contents read/write scope
GITHUB_OWNER=              # GitHub repo owner (username or org)
GITHUB_REPO=               # GitHub repo name

# Required for legacy import (one-time)
# NOTION_API_KEY=          # Notion API key (only needed if using official SDK)
