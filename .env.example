# Public site URL for canonical/OG/sitemap/share links.
# Optional: on Vercel this auto-resolves from VERCEL_PROJECT_PRODUCTION_URL,
# falling back to https://cc0-lib.xyz. Set this in production so canonical/OG/embed
# URLs (and the Farcaster manifest) all agree on the canonical apex domain.
NEXT_PUBLIC_SITE_URL=https://cc0-lib.xyz

# Required for the /api/submit endpoint (commits new items to GitHub metadata.json)
GITHUB_TOKEN=              # GitHub PAT with repo contents read/write scope
GITHUB_OWNER=              # GitHub repo owner (username or org, e.g. BeanInTheMachine)
GITHUB_REPO=               # GitHub repo name (e.g. cc0-lib)

# Optional — WalletConnect project ID for the /upload page wallet modal.
# Get one at https://cloud.walletconnect.com/ (free).
# Without this, only injected wallets (MetaMask) are supported.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Required for legacy import (one-time)
# NOTION_API_KEY=          # Notion API key (only needed if using official SDK)

# Farcaster Mini App account association (proves domain + author ownership).
# The signed values for cc0-lib.xyz are already committed in
# src/app/.well-known/farcaster.json/route.ts. These env vars are OPTIONAL and
# only needed to override them (e.g. a new domain/account) without a code edit.
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=
